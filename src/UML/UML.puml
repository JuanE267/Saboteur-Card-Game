@startuml Saboteur_DiagramaDeClases

title Saboteur — Diagrama de clases completo (con notificación de herramientas)

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classHeaderBackgroundColor #f0f0f0
skinparam classBorderColor #888888
skinparam arrowColor #555555
skinparam packageBorderColor #aaaaaa
skinparam packageBackgroundColor #fafafa
skinparam linetype ortho

' Orden izquierda → derecha: Modelo | Controlador | Vista
left to right direction

' ═══════════════════════════════════════
' ENUMS
' ═══════════════════════════════════════

package "Modelo.Enums" #EAF3DE {

    enum Rol {
        MINERO
        SABOTEADOR
    }

    enum Herramienta {
        PICO
        LINTERNA
        VAGONETA
    }

    enum TipoCarta {
        TUNEL
        ACCION
        DESTINO
    }

    enum TipoAccion {
        ROMPERPICO
        ROMPERLINTERNA
        ROMPERVAGONETA
        DERRUMBAR
        REPARARPICO
        REPARARVAGONETA
        REPARARLINTERNA
        OBJETIVO_REPARAR
        OBJETIVO_ROMPER
        MAPA
        JUGADA
    }

    enum Direccion {
        ARRIBA
        ABAJO
        IZQUIERDA
        DERECHA
    }

    enum Evento {
        DESCARTAR_CARTA
        ACTUALIZAR_HERRAMIENTAS
        JUGAR_CARTA_TABLERO
        TOMAR_CARTA
        PASAR_TURNO
        NUEVO_USUARIO
        INICIAR_PARTIDA
        NUEVA_RONDA_GANADOR_MINEROS
        NUEVA_RONDA_GANADOR_SABOTEADORES
        FINALIZAR_PARTIDA_MINEROS
        FINALIZAR_PARTIDA_SABOTEADORES
        CARGAR_PARTIDA
        SERVIDOR_NOTIFICA_CLIENTE
        HERRAMIENTA_ROTA
        HERRAMIENTA_REPARADA
    }
}

' ═══════════════════════════════════════
' MODELO — CARTAS
' ═══════════════════════════════════════

package "Modelo.Cartas" #E6F1FB {

    abstract class Carta {
        - id : int
        - tipo : TipoCarta
        - img : String
        - esDestino : boolean
        - rotada : boolean
        --
        + getTipo() : TipoCarta
        + getImg() : String
        + setImg(img : String)
        + esDestino() : boolean
        + setEsDestino(v : boolean)
        + isRotada() : boolean
        + setRotada(v : boolean)
    }

    class CartaTunel {
        - caminos : Map<Direccion, Boolean>
        - esInicio : boolean
        - rotacion : int
        --
        + getCaminos() : Map<Direccion, Boolean>
        + setCaminos(arriba, abajo, izq, der : boolean)
        + puedeConectar(vecino : CartaTunel, dir : Direccion) : Boolean
        + rotar()
        + getEsInicio() : boolean
    }

    class CartaDestino {
        - esOro : boolean
        - oroX : int
        - oroY : int
        - dorso : String
        - cara : String
        - fueGirada : boolean
        --
        + girar()
        + getEsOro() : boolean
        + getOroX() : int
        + getOroY() : int
        + setOroX(x : int)
        + setOroY(y : int)
        + getDorso() : String
        + getCara() : String
        + setDorso(img : String)
        + setearCaminos()
    }

    class CartaAccion {
        - tipo : List<TipoAccion>
        --
        + getTipoAccion() : List<TipoAccion>
        + setTipo(tipos : List<TipoAccion>)
        + jugarCarta(afectado : IJugador, herramientaPresionada : Herramienta) : Boolean
        + jugarCarta(x, y : int, tablero : Tablero) : Boolean
        + verDestino(x, y : int, tablero : Tablero) : Boolean
        + esReparar() : boolean
        - romperHerramienta(afectado : IJugador, tipoAccion : TipoAccion) : Boolean
        - repararHerramienta(afectado : IJugador, tipoAccion : TipoAccion) : Boolean
        - DerrumbarTunel(x, y : int, tablero : Tablero) : Boolean
        - TipoAccionAHerramienta(tipoAccion : TipoAccion) : Herramienta
    }

    Carta <|-- CartaTunel
    CartaTunel <|-- CartaDestino
    Carta <|-- CartaAccion
}

' ═══════════════════════════════════════
' MODELO
' ═══════════════════════════════════════

package "Modelo" #EEEDFE {

    class EventoHerramienta <<nuevo>> {
        - tipo : Evento
        - nombreActor : String
        - nombreAfectado : String
        - herramienta : Herramienta
        --
        + getTipo() : Evento
        + getNombreActor() : String
        + getNombreAfectado() : String
        + getHerramienta() : Herramienta
    }

    interface IJugador {
        + jugarCarta(tablero, x, y, carta) : boolean
        + jugarCarta(afectado, carta, herramienta) : boolean
        + jugarCartaMapaDerrumbe(tablero, x, y, carta) : Boolean
        + elegirCarta(posCarta : int) : Carta
        + descartarCarta(posCarta : int) : Boolean
        + getNombre() : String
        + getRol() : Rol
        + setRol(rol : Rol)
        + getManoCartas() : List<Carta>
        + setManoCartas(cartas : List<Carta>)
        + getHerramientasRotas() : List<Herramienta>
        + setHerramientasRotas(herrs : List<Herramienta>)
        + reiniciarEstado()
        + getEdad() : int
        + setEdad(edad : int)
        + setNombre(nombre : String)
        + getPuntaje() : int
        + setPuntaje(puntaje : int)
        + sumarPuntos(puntos : int)
        + getId() : int
        + setId(id : int)
        + puedeConstruir() : Boolean
    }

    class Jugador {
        - nombre : String
        - {static} ID : int
        - id : int
        - edad : int
        - rol : Rol
        - manoCartas : List<Carta>
        - herramientasRotas : List<Herramienta>
        - puntaje : int
        --
        + {static} resetID()
        + jugarCarta(tablero, x, y, carta) : boolean
        + jugarCarta(afectado, carta, herramienta) : boolean
        + jugarCartaMapaDerrumbe(tablero, x, y, carta) : Boolean
        + elegirCarta(posCarta : int) : Carta
        + descartarCarta(posCarta : int) : Boolean
        + puedeConstruir() : Boolean
        + sumarPuntos(puntos : int)
        + reiniciarEstado()
        ... getters / setters ...
    }

    record Posicion {
        + x : int
        + y : int
    }

    class Tablero {
        - tablero : Map<Posicion, Carta>
        - xInicio : int
        - yInicio : int
        - xOro : int
        - yOro : int
        --
        + inicializarTablero()
        + colocarCarta(carta : CartaTunel, x, y : int) : boolean
        + getCarta(x, y : int) : Carta
        + setCarta(carta : Carta, x, y : int)
        + hayCaminoHastaOro() : boolean
        - puedeColocarCarta(carta : CartaTunel, x, y : int) : boolean
        - getVecino(x, y : int, dir : Direccion) : CartaTunel
    }

    class Mazo {
        - cartas : List<Carta>
        --
        + barajarMazo()
        + tomarCarta() : Carta
        + noHayCartas() : boolean
        - inicializarMazo()
    }

    class Ranking {
        --
        + {static} guardarRanking(nombre : String, puntaje : int)
        + {static} obtenerRanking() : List<String>
    }

    interface IJuego <<remote>> {
        + iniciarPartida()
        + iniciarPartidaCargadaDesdeServidor()
        + iniciarPartidaCargadaDesdeCliente(nombreCliente : String)
        + agregarJugador(nombre : String, edad : int) : IJugador
        + asignoPrimerTurno(ronda : int)
        + getTablero() : Tablero
        + asignarRoles()
        + pasarTurno()
        + finalizarRonda(ganaronLosMineros : boolean)
        + jugarCarta(x, y, posCarta : int, objetivo : IJugador, rotada : boolean) : Boolean
        + jugarHerramienta(objetivo : IJugador, posCarta : int, herramienta : Herramienta) : boolean
        + getMazo() : Mazo
        + getJugadores() : IJugador[]
        + getJugadorActual() : IJugador
        + reiniciarRonda(ronda : int)
        + hayCaminoHastaOro() : boolean
        + noHayCartas() : boolean
        + verificarSiTerminoLaRonda() : boolean
        + descartarCarta(posCarta : int)
        + getGanador() : IJugador
        + getJugadorPorId(id : int) : IJugador
        + getRonda() : int
        + getGanadorRonda() : IJugador
        + cargarPartida() : boolean
        + guardarPartida() : boolean
    }

    class Juego {
        - jugadores : HashMap<Integer, IJugador>
        - jugadoresCargados : HashMap<Integer, IJugador>
        - mazo : Mazo
        - tablero : Tablero
        - roles : List<Rol>
        - turnoInicial : int
        - ronda : int
        - ordenTurnos : List<Integer>
        - turno : int
        - ganador : IJugador
        - ganadorRonda : IJugador
        --
        + iniciarPartida()
        + agregarJugador(nombre, edad) : IJugador
        + asignarRoles()
        + asignoPrimerTurno(ronda : int)
        + pasarTurno()
        + finalizarRonda(ganaronLosMineros : boolean)
        + jugarCarta(x, y, posCarta, objetivo, rotada) : Boolean
        + jugarHerramienta(objetivo, posCarta, herramienta) : boolean
        + verificarSiTerminoLaRonda() : boolean
        + descartarCarta(posCarta : int)
        + reiniciarRonda(ronda : int)
        + reiniciarPartida()
        + repartirCartas() : List<Carta>
        + cargarPartida() : boolean
        + guardarPartida() : boolean
        + validarCarga() : boolean
        - robarCartaAuto(jugador : IJugador)
        - pepitasMineros() : List<Integer>
        - pepitasSaboteadores() : int
        - todosLosJugadoresSinCartasTunel() : boolean
        - detectarHerramientaCambiada(antes, despues) : Herramienta
    }

    IJugador <|.. Jugador
    IJuego <|.. Juego
    Juego "1" *-- "1" Mazo
    Juego "1" *-- "1" Tablero
    Juego "1" o-- "1..*" IJugador
    Juego ..> EventoHerramienta : <<crea>>
    Tablero "1" o-- "*" Carta
    Tablero "1" *-- "*" Posicion
    Jugador "1" o-- "*" Carta : manoCartas
    Jugador "1" o-- "*" Herramienta : herramientasRotas
    Mazo "1" o-- "*" Carta
    EventoHerramienta --> Evento
    EventoHerramienta --> Herramienta
}

' ═══════════════════════════════════════
' CONTROLADOR  (centro del MVC)
' ═══════════════════════════════════════

package "Controlador" #FAECE7 {

    class Controlador <<IControladorRemoto>> {
        - juego : IJuego
        - esPartidaCargada : boolean
        - ventanaGanador : VentanaGanador
        - vistaServidor : IVistaServidor
        - vista : IVistaGrafica
        - jugadorCliente : IJugador
        - esHost : boolean
        --
        + conectarUsuario(nombre, edad) : IJugador
        + getJugadorActualizado() : IJugador
        + actualizarJugador()
        + actualizarJugadorPorNombre()
        + pasarTurno()
        + verificarSiTerminoLaRonda() : boolean
        + jugarUnaCarta(x, y, posCarta, objetivo, rotada) : Boolean
        + jugarHerramienta(posCarta, idObjetivo, herramientaPresionada) : TipoAccion
        + descartarCarta(posCarta : int)
        + esTurnoDe(jugador : IJugador) : Boolean
        + getTablero() : Tablero
        + getJugadores() : IJugador[]
        + getJugadorActual() : IJugador
        + getJugadorPorId(id : int) : IJugador
        + iniciarPartida() : Boolean
        + crearPartida(ipServidor, puertoCliente)
        + unirseAPartida(ipServidor, ipCliente, puertoCliente)
        + guardarPartida()
        + cargarPartida()
        + avisarGanadores(evento, ganadorRonda)
        + actualizar(observable, o : Object)
        + esHost() : boolean
        + obtenerRanking() : List<String>
        + setVistaGrafica(vista)
        + setVistaServidor(vista)
        + setJugadorCliente(jugador)
    }

    Controlador "1" --> "1" IJuego         : llama
    Controlador ..> EventoHerramienta      : <<recibe y procesa>>
    Controlador "1" --> "1" IVistaGrafica  : notifica
    Controlador "1" --> "0..1" IVistaServidor
    Controlador "1" --> "0..1" IJugador    : jugadorCliente
}

' ═══════════════════════════════════════
' VISTA — INTERFACES Y VENTANAS
' ═══════════════════════════════════════

package "Vista" #FFF9E6 {

    interface IVistaGrafica {
        + actualizar(tablero : Tablero, jugadores : IJugador[])
        + iniciar()
        + mostrarPartida()
        + ocultarPartida()
    }

    interface IVistaServidor {
        + actualizarListaJugadores(jugadores : IJugador[])
    }

    class VistaGrafica {
        - ventanaInicioSesion : VentanaInicioSesion
        - ventanaJuego : VentanaJuego
        - ventanaEspera : JFrame
        - controlador : Controlador
        --
        + iniciar()
        + mostrarPartida()
        + ocultarPartida()
        + actualizar(tablero, jugadores)
        + mostrarPantallaEspera()
        - iniciarVentanaJuego() : VentanaJuego
    }

    class VentanaBienvenida {
        - controlador : Controlador
        --
        + iniciar()
    }

    class VentanaServidor {
        - controlador : Controlador
        - listaJugadores : JList
        --
        + iniciar()
        + actualizarListaJugadores(jugadores : IJugador[])
    }

    class VentanaInicioSesion {
        - txtNombre : JTextField
        - txtEdad : JTextField
        --
        + getNombreJugador() : String
        + getEdadJugador() : int
        + onClickEntrar(listener)
    }

    class VentanaGanador {
        - controlador : Controlador
        --
        + mostrarVentana(evento, ganador, ganadorRonda)
        + actualizarCuentaRegresiva(segundos : int)
    }

    class VentanaRanking {
        --
        + mostrar(ranking : List<String>)
    }

    IVistaGrafica <|.. VistaGrafica
    IVistaServidor <|.. VentanaServidor
    VistaGrafica "1" *-- "1" VentanaInicioSesion
    VistaGrafica "1" *-- "0..1" VentanaJuego
}

' ═══════════════════════════════════════
' VISTA — VENTANA JUEGO
' ═══════════════════════════════════════

package "Vista.VistaJuego" #FFF0E6 {

    class VentanaJuego {
        - panelTablero : PanelTablero
        - panelJugador : PanelJugador
        - panelHerramientas : PanelHerramientas
        - panelTablaJugadores : PanelTablaJugadores
        - panelPuntosYAcciones : PanelPuntosYAcciones
        - panelTomarCarta : PanelTomarCarta
        - controlador : Controlador
        --
        + actualizarVentana()
        + getPanelTablero() : PanelTablero
        + getPanelJugador() : PanelJugador
        + getPanelHerramientas() : PanelHerramientas
        + getPanelTablaJugadores() : PanelTablaJugadores
        + getPanelPuntosYAcciones() : PanelPuntosYAcciones
        + getPanelTomarCarta() : PanelTomarCarta
    }

    class PanelTablero {
        - tablero : Tablero
        - jugadorCliente : IJugador
        - controlador : Controlador
        - casilleros : Casillero[][]
        --
        + actualizar(tablero, jugador)
        - dibujarTablero()
        - casilleroPresionado(x, y)
    }

    class PanelJugador {
        - jugadorCliente : IJugador
        - controlador : Controlador
        - vistaManoActual : List<BotonCarta>
        - cartaSeleccionada : int
        - cartaRotada : boolean
        --
        + actualizar(jugador : IJugador)
        + getCartaSeleccionada() : int
        + resetCartaSeleccionada()
        - dibujarManoDeCartas()
        - cartaEnMazoPresionada(boton : BotonCarta)
    }

    class PanelHerramientas {
        - jugadorCliente : IJugador
        --
        + actualizar(jugador : IJugador)
        - dibujarHerramientas()
    }

    class PanelTablaJugadores {
        - jugadorCliente : IJugador
        - jugadores : IJugador[]
        - controlador : Controlador
        - panelJugador : PanelJugador
        --
        + actualizar(jugadores, jugadorCliente)
        - dibujarListaJugadores(jugadorCliente)
        - herramientaEsPresionada(herr : HerramientaTabla)
        - setImagen(herr, url)
        - mensajeNoEsTuTurno()
    }

    class PanelPuntosYAcciones {
        - jugadorCliente : IJugador
        - controlador : Controlador
        --
        + actualizar(jugador : IJugador)
        - configurarBotones()
    }

    class PanelTomarCarta {
        - controlador : Controlador
        --
        + actualizar()
    }

    class Casillero {
        - x : int
        - y : int
        - carta : Carta
        --
        + getCarta() : Carta
        + setCarta(carta : Carta)
    }

    class BotonCarta {
        - cartaAsociada : Carta
        --
        + getCartaAsociada() : Carta
    }

    class HerramientaTabla {
        - dueño : IJugador
        - herramienta : Herramienta
        --
        + getDueño() : IJugador
        + getHerramienta() : Herramienta
    }

    VentanaJuego "1" *-- "1" PanelTablero
    VentanaJuego "1" *-- "1" PanelJugador
    VentanaJuego "1" *-- "1" PanelHerramientas
    VentanaJuego "1" *-- "1" PanelTablaJugadores
    VentanaJuego "1" *-- "1" PanelPuntosYAcciones
    VentanaJuego "1" *-- "1" PanelTomarCarta
    PanelTablero "1" *-- "*" Casillero
    PanelJugador "1" *-- "*" BotonCarta
    PanelTablaJugadores "1" *-- "*" HerramientaTabla
    PanelTablaJugadores --> PanelJugador
    VistaGrafica --> VentanaJuego
}

' ═══════════════════════════════════════
' PUNTO DE ENTRADA
' ═══════════════════════════════════════

package "Saboteur" #F1EFE8 {
    class Saboteur {
        + {static} main(args : String[])
    }
    Saboteur --> VentanaBienvenida
}

' ═══════════════════════════════════════
' RELACIONES CROSS-PACKAGE
' ═══════════════════════════════════════

CartaAccion --> TipoAccion
CartaAccion --> Herramienta
CartaTunel --> Direccion
Carta --> TipoCarta
Jugador --> Rol
Juego --> Evento
Controlador --> Evento
Controlador --> TipoAccion
VentanaGanador --> Evento
VistaGrafica --> VentanaGanador
VistaGrafica --> VentanaServidor
VistaGrafica --> VentanaInicioSesion
VentanaBienvenida --> Controlador
VentanaRanking --> Controlador

@enduml